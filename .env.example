# PortWise AI - Environment Configuration
# Copy this file to .env and fill in your API keys

# ── Required ──────────────────────────────────────────────────────────────────
# Google Gemini API Key — get yours free at https://ai.google.dev/
# Leave as placeholder to run in demo mode (LLM features disabled).
GEMINI_API_KEY="AIzaSyAh4JuHFmnVhcWhgW1T1rAHrhs6EsWi0lY"

# ── Optional ──────────────────────────────────────────────────────────────────
# OpenWeather API key for weather-based predictions (not yet wired in v1.0)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ── App settings ──────────────────────────────────────────────────────────────
DEBUG=false
APP_NAME=PortWise AI
APP_VERSION=1.0.0

# ── Streamlit server ──────────────────────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# ── Vector database ───────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=maritime_docs

# ── Prediction engine ─────────────────────────────────────────────────────────
# Seed for reproducible synthetic predictions in demo mode
RANDOM_SEED=42

# ── Redis (optional, for production caching) ──────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
